# Application Identity
APP_ENV=development
DEBUG=True
PORT=8001
LOG_LEVEL=DEBUG

# Authentication
JWT_SECRET=super_secret_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=86400

# Infrastructure
# DATABASE_URL=postgresql://user:password@localhost:5432/sm_auth
REDIS_URL=redis://localhost:6379/0

# backend/services/auth/.env
DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/auth_db
