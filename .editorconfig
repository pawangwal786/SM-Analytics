# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# JavaScript / TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# CSS
[*.{css,scss,sass}]
indent_size = 2

# HTML
[*.html]
indent_size = 2

# React
[*.{tsx,jsx}]
indent_size = 2

# Go
[*.go]
indent_style = tab

# Makefiles
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 4

# Dockerfiles
[Dockerfile]
indent_size = 4

# SQL
[*.sql]
indent_size = 4

# Java
[*.java]
indent_size = 4

# Python
[*.py]
indent_size = 4

# TOML
[*.toml]
indent_size = 4

# XML
[*.xml]
indent_size = 4

# Properties
[*.properties]
indent_size = 2
