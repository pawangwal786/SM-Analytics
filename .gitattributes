# Auto-detect text files and normalize to LF in the repository
* text=auto eol=lf

# Source files
*.py     text eol=lf
*.go     text eol=lf
*.java   text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.xml    text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf
*.env.example text eol=lf
Makefile text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary