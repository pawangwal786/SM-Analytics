# POSTGRES_DB=sm_analytics
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# REDIS_PASSWORD=redis
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# SM Analytics
# Environment Configuration Template
# Copy this file to .env before running the application.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=SM Analytics
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/sm_analytics

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true

DATABASE_SSLMODE=prefer
DATABASE_STATEMENT_TIMEOUT=
DATABASE_CONNECT_TIMEOUT=10
DATABASE_APPLICATION_NAME=sm-analytics

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:redis@redis:6379/0
REDIS_PASSWORD=redis

# -----------------------------------------------------------------------------
# PostgreSQL Container Initialization
# -----------------------------------------------------------------------------
POSTGRES_DB=sm_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-secure-random-secret
